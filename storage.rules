// Firebase Storage rules — доступ к фото по членству в каталоге.
// Правила Storage умеют читать Firestore: файл виден тем, кто есть в members.
//
// ⚠️ Деплой: Firebase Console → Storage → Rules (или firebase deploy --only storage).
// Пути файлов: catalogs/{cid}/items/{itemId}/{n}.jpg (+ {n}_thumb.jpg).
rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    match /catalogs/{cid}/{allPaths=**} {
      allow read, write: if request.auth != null
        && firestore.exists(/databases/(default)/documents/catalogs/$(cid)/members/$(request.auth.uid));
    }
  }
}
