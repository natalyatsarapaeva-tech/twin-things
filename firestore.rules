// Firestore rules для Twin Things — доступ = членство в каталоге.
// Роли MVP: owner | editor. viewer — отдельная волна (сейчас любой член пишет).
//
// ⚠️ Пока эти правила не задеплоены, база в test mode (открыта всем).
// Деплой: Firebase Console → Firestore Database → Rules
//   (или firebase deploy --only firestore:rules).
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() { return request.auth != null; }
    function uid() { return request.auth.uid; }

    // Профиль + индекс «мои каталоги» (денормализация; сам по себе прав не даёт).
    match /users/{u} {
      allow read, write: if signedIn() && u == uid();
      match /catalogs/{cid} {
        allow read, write: if signedIn() && u == uid();
      }
    }

    match /catalogs/{cid} {
      function isMember() {
        return exists(/databases/$(database)/documents/catalogs/$(cid)/members/$(uid()));
      }
      function role() {
        return get(/databases/$(database)/documents/catalogs/$(cid)/members/$(uid())).data.role;
      }

      allow read:   if isMember();
      allow create: if signedIn() && request.resource.data.ownerUid == uid();
      allow update, delete: if isMember() && role() == 'owner';

      match /members/{m} {
        allow read: if isMember();
        // Создатель каталога записывает первого владельца (себя);
        // дальше участниками управляет только owner.
        allow create: if signedIn()
          && (m == uid() && request.resource.data.role == 'owner'
              && get(/databases/$(database)/documents/catalogs/$(cid)).data.ownerUid == uid())
          || (isMember() && role() == 'owner');
        allow update, delete: if isMember() && role() == 'owner';
      }

      // invites — Wave 2 (email-приглашения). Читать может член или сам приглашённый.
      match /invites/{i} {
        allow read:   if isMember() || resource.data.email == request.auth.token.email;
        allow create, delete: if isMember() && role() == 'owner';
      }

      // Вещи и таксономия — правит любой член (owner|editor); viewer появится позже.
      match /items/{id} {
        allow read:  if isMember();
        allow write: if isMember();
      }
      match /meta/{id} {
        allow read:  if isMember();
        allow write: if isMember();
      }
    }
  }
}
